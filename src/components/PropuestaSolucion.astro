<!-- ── SCRIPT: Reveal secciones + animación dona ── -->
<script>
  // ── 1. Reveal de secciones ───────────────────────────────
  const solSections = document.querySelectorAll<HTMLElement>('[data-sol-reveal]');

  const solObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');

          // Si es la sección de la dona, dispara la animación
          const dona = entry.target.querySelector<SVGElement>('.ps-dona');
          if (dona && !dona.classList.contains('is-animated')) {
            animateDona(dona);
          }
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  );

  solSections.forEach((el) => solObserver.observe(el));

  // ── 2. Animación de la dona ──────────────────────────────
  // C = 2π·80 = 502.655
  // dashoffset = C/4 − acc·C  (segmento empieza donde termina el anterior)
  // La animación crece stroke-dasharray de "0 C" al valor final;
  // stroke-dashoffset se fija una sola vez y no se toca más.
  function animateDona(dona: SVGElement) {
    dona.classList.add('is-animated');

    const C = 502.655;

    const segData = [
      // Orden de aparición (stagger visual): eco → social → reserva → libre
      { id: '#seg-eco',     len: 100.531, dashoffset:  125.664 },
      { id: '#seg-social',  len: 100.531, dashoffset:   25.133 },
      { id: '#seg-reserva', len:  50.265, dashoffset:  -75.398 },
      { id: '#seg-libre',   len: 251.328, dashoffset: -125.664 },
    ];

    const duration = 800; // ms para que cada arco crezca
    const stagger  = 150; // ms entre el inicio de cada arco

    segData.forEach(({ id, len, dashoffset }, i) => {
      const el = dona.querySelector<SVGCircleElement>(id);
      if (!el) return;

      const gap = C - len;

      // 1. Fijar estado inicial: visible pero con arco = 0
      el.style.transition = 'none';
      el.style.opacity = '1';
      el.style.strokeDashoffset = String(dashoffset); // posición correcta, fija
      el.style.strokeDasharray  = `0 ${C}`;

      // 2. Disparar la animación del arco tras el stagger
      setTimeout(() => {
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            el.style.transition = `stroke-dasharray ${duration}ms cubic-bezier(0.35,0,0.15,1)`;
            el.style.strokeDasharray = `${len} ${gap}`;
          });
        });
      }, i * stagger);
    });
  }
</script>
