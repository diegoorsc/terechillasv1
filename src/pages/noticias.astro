---
import Base from '../layouts/Base.astro';

// Lee todos los archivos .md de src/content/noticias/ en tiempo de build
const archivos = await Astro.glob('../content/noticias/*.md');

// Ordena por fecha descendente
const noticias = archivos
  .map((n) => ({
    titulo:  n.frontmatter.titulo  ?? 'Sin título',
    fecha:   n.frontmatter.fecha   ?? '',
    resumen: n.frontmatter.resumen ?? '',
    url:     n.url ?? '#',
  }))
  .sort((a, b) => (a.fecha < b.fecha ? 1 : -1));

// Formatea fecha legible en español
function formatFecha(iso: string): string {
  if (!iso) return '';
  try {
    return new Date(iso).toLocaleDateString('es-CL', {
      day:   'numeric',
      month: 'long',
      year:  'numeric',
      timeZone: 'UTC',
    });
  } catch {
    return iso;
  }
}
---

<Base
  title="Noticias"
  description="Novedades y actualizaciones del equipo Terechillas del Choapa."
>

  <!-- HERO -->
  <section class="nc-hero">
    <div class="nc-hero__inner">
      <p class="nc-eyebrow">Novedades</p>
      <h1 class="nc-title">Noticias del equipo.</h1>
      <p class="nc-bajada">
        Actualizaciones sobre el Torneo Delibera 2026, nuestra
        propuesta y la actividad del equipo en la Provincia del Choapa.
      </p>
    </div>
  </section>

  <!-- LISTADO -->
  <section class="nc-lista">
    <div class="nc-lista__inner">
      {noticias.length === 0 ? (
        <p class="nc-vacio">No hay noticias publicadas aún.</p>
      ) : (
        <ul class="nc-grid" role="list">
          {noticias.map((n) => (
            <li class="nc-card">
              {n.fecha && (
                <time class="nc-card__fecha" datetime={n.fecha}>
                  {formatFecha(n.fecha)}
                </time>
              )}
              <h2 class="nc-card__titulo">{n.titulo}</h2>
              {n.resumen && (
                <p class="nc-card__resumen">{n.resumen}</p>
              )}
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

</Base>

<style>
  /* ── HERO ── */
  .nc-hero {
    padding: calc(var(--nav-height, 64px) + 4rem) 1.5rem 5rem;
    text-align: center;
    background:
      radial-gradient(ellipse 70% 50% at 50% 0%,
        rgba(200,146,42,0.09) 0%, transparent 65%),
      #1a2942;
    background:
      radial-gradient(ellipse 70% 50% at 50% 0%,
        rgba(200,146,42,0.09) 0%, transparent 65%),
      var(--color-bg, #1a2942);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .nc-hero__inner {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
  }

  .nc-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c8922a;
    color: var(--color-accent, #c8922a);
  }

  .nc-title {
    font-family: var(--font-display, 'Georgia', serif);
    font-size: clamp(1.9rem, 5vw, 3.2rem);
    font-weight: 700;
    color: #f0f4f8;
    color: var(--color-text, #f0f4f8);
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  .nc-bajada {
    font-size: 1rem;
    color: #9dafc5;
    color: var(--color-text-muted, #9dafc5);
    line-height: 1.75;
    max-width: 460px;
  }

  /* ── LISTADO ── */
  .nc-lista {
    padding: 4.5rem 1.5rem 6rem;
    background-color: #111d30;
    background-color: var(--color-bg-dark, #111d30);
  }

  .nc-lista__inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .nc-vacio {
    text-align: center;
    color: #6b83a0;
    color: var(--color-text-dim, #6b83a0);
    font-size: 1rem;
    padding: 3rem 0;
  }

  .nc-grid {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .nc-card {
    padding: 1.75rem 1.5rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-left: 3px solid #c8922a;
    border-left-color: var(--color-accent, #c8922a);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    transition: background 0.2s;
  }
  .nc-card:hover {
    background: rgba(255,255,255,0.07);
  }

  .nc-card__fecha {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #c8922a;
    color: var(--color-accent, #c8922a);
  }

  .nc-card__titulo {
    font-family: var(--font-display, 'Georgia', serif);
    font-size: clamp(1.05rem, 2.5vw, 1.3rem);
    font-weight: 600;
    color: #f0f4f8;
    color: var(--color-text, #f0f4f8);
    line-height: 1.3;
  }

  .nc-card__resumen {
    font-size: 0.9rem;
    color: #9dafc5;
    color: var(--color-text-muted, #9dafc5);
    line-height: 1.7;
  }
</style>
