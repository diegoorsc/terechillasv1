---
import Base from '../layouts/Base.astro';
import integrantes from '../content/equipo/integrantes.json';

// Datos del profesor guía — editar aquí cuando se tenga el apellido
const profesorGuia = {
  nombre: 'Sergio',
  apellido: '',          // ← completar cuando esté disponible
  descripcion:
    'Nuestro profesor guía nos acompañó en cada etapa del proceso: '
    + 'desde el diagnóstico territorial hasta la redacción de la '
    + 'Iniciativa Juvenil de Ley, orientando la investigación y '
    + 'el rigor argumentativo de la propuesta.',
};
const nombreProfesor = [profesorGuia.nombre, profesorGuia.apellido]
  .filter(Boolean)
  .join(' ');
---

<Base
  title="Equipo"
  description="Conoce a los estudiantes del Colegio Santa Teresa de Illapel que representan al Choapa en el Torneo Delibera 2026."
>

  <!-- ── HERO ── -->
  <section class="eq-hero">
    <div class="eq-hero__inner">
      <p class="eq-eyebrow">El equipo</p>
      <h1 class="eq-title">
        Quiénes están detrás de esta&nbsp;iniciativa.
      </h1>
      <p class="eq-bajada">
        Somos cuatro estudiantes del Colegio Santa Teresa de Illapel que
        decidimos representar a la Provincia del Choapa en el Torneo
        Delibera 2026. Nuestra propuesta nació del territorio que habitamos
        y de las preguntas que nos hicimos sobre él.
      </p>
    </div>
  </section>

  <!-- ── TARJETAS DE INTEGRANTES ── -->
  <section class="eq-miembros">
    <div class="eq-miembros__inner">
      <p class="eq-section-eyebrow">Integrantes</p>
      <ul class="eq-grid" role="list">
        {integrantes.map((persona) => (
          <li class="eq-card">
            <!-- Foto / placeholder con iniciales -->
            <div class="eq-card__foto-wrap">
              <img
                src={persona.foto}
                alt={`Foto de ${persona.nombre}`}
                class="eq-card__foto"
                width="120"
                height="120"
                onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
              />
              <div class="eq-card__iniciales" aria-hidden="true" style="display:none">
                {persona.iniciales}
              </div>
            </div>

            <!-- Info -->
            <div class="eq-card__info">
              <p class="eq-card__rol">{persona.rol}</p>
              <h2 class="eq-card__nombre">{persona.nombre}</h2>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── PROFESOR GUÍA ── -->
  <section class="eq-profesor">
    <div class="eq-profesor__inner">
      <div class="eq-profesor__badge" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.8"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
          <path d="M6 12v5c3 3 9 3 12 0v-5"/>
        </svg>
      </div>
      <div class="eq-profesor__texto">
        <p class="eq-section-eyebrow">Acompañamiento académico</p>
        <h2 class="eq-profesor__nombre">
          Profesor guía: <span>{nombreProfesor || 'Profesor Sergio'}</span>
        </h2>
        <p class="eq-profesor__desc">{profesorGuia.descripcion}</p>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ── Variables locales ── */
  :root {
    --eq-card-radius: 12px;
  }

  /* ════════ HERO ════════ */
  .eq-hero {
    padding: calc(var(--nav-height, 64px) + 4rem) 1.5rem 5rem;
    text-align: center;
    background:
      radial-gradient(ellipse 70% 50% at 50% 0%,
        rgba(200,146,42,0.09) 0%, transparent 65%),
      #1a2942;
    background:
      radial-gradient(ellipse 70% 50% at 50% 0%,
        rgba(200,146,42,0.09) 0%, transparent 65%),
      var(--color-bg, #1a2942);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .eq-hero__inner {
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .eq-eyebrow,
  .eq-section-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c8922a;
    color: var(--color-accent, #c8922a);
  }

  .eq-title {
    font-family: var(--font-display, 'Georgia', serif);
    font-size: clamp(1.9rem, 5vw, 3.2rem);
    font-weight: 700;
    color: #f0f4f8;
    color: var(--color-text, #f0f4f8);
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  .eq-bajada {
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    color: #9dafc5;
    color: var(--color-text-muted, #9dafc5);
    line-height: 1.75;
    max-width: 520px;
  }

  /* ════════ TARJETAS ════════ */
  .eq-miembros {
    padding: 5rem 1.5rem;
    background-color: #111d30;
    background-color: var(--color-bg-dark, #111d30);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .eq-miembros__inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  .eq-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    width: 100%;
  }

  /* Tarjeta */
  .eq-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding: 2rem 1.25rem 1.75rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-top: 2px solid rgba(200,146,42,0.3);
    border-radius: var(--eq-card-radius);
    text-align: center;
    transition: transform 0.22s ease, background 0.22s ease,
                border-top-color 0.22s ease;
  }

  .eq-card:hover {
    transform: translateY(-5px);
    background: rgba(255,255,255,0.07);
    border-top-color: #c8922a;
    border-top-color: var(--color-accent, #c8922a);
  }

  /* Foto circular */
  .eq-card__foto-wrap {
    position: relative;
    width: 96px;
    height: 96px;
    flex-shrink: 0;
  }

  .eq-card__foto {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(200,146,42,0.35);
    background: #223354;
  }

  /* Placeholder con iniciales — se activa via onerror */
  .eq-card__iniciales {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #223354;
    border: 2px solid rgba(200,146,42,0.35);
    align-items: center;
    justify-content: center;
    font-family: var(--font-display, 'Georgia', serif);
    font-size: 1.35rem;
    font-weight: 700;
    color: #c8922a;
    color: var(--color-accent, #c8922a);
    letter-spacing: 0.04em;
    user-select: none;
  }

  /* Info */
  .eq-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .eq-card__rol {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #c8922a;
    color: var(--color-accent, #c8922a);
  }

  .eq-card__nombre {
    font-family: var(--font-display, 'Georgia', serif);
    font-size: 1.05rem;
    font-weight: 600;
    color: #f0f4f8;
    color: var(--color-text, #f0f4f8);
    line-height: 1.25;
  }

  /* Responsive grid */
  @media (max-width: 800px) {
    .eq-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .eq-grid { grid-template-columns: 1fr; max-width: 320px; }
    .eq-miembros__inner { align-items: center; }
  }

  /* ════════ PROFESOR GUÍA ════════ */
  .eq-profesor {
    padding: 4.5rem 1.5rem;
    background-color: #1e2f4a;
    background-color: var(--color-bg-section, #1e2f4a);
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .eq-profesor__inner {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  .eq-profesor__badge {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(200,146,42,0.1);
    border: 1px solid rgba(200,146,42,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #c8922a;
    color: var(--color-accent, #c8922a);
    margin-top: 0.25rem;
  }

  .eq-profesor__texto {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .eq-profesor__nombre {
    font-family: var(--font-display, 'Georgia', serif);
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    font-weight: 600;
    color: #f0f4f8;
    color: var(--color-text, #f0f4f8);
    line-height: 1.3;
  }

  .eq-profesor__nombre span {
    color: #c8922a;
    color: var(--color-accent, #c8922a);
  }

  .eq-profesor__desc {
    font-size: 0.92rem;
    color: #9dafc5;
    color: var(--color-text-muted, #9dafc5);
    line-height: 1.75;
  }

  @media (max-width: 560px) {
    .eq-profesor__inner { flex-direction: column; gap: 1.25rem; }
  }
</style>
