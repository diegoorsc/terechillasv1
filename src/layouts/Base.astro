---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Terechillas del Choapa',
  description = 'Sitio oficial del equipo escolar Terechillas del Choapa — Torneo Delibera 2026.',
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1a2942" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <title>{title} — Terechillas del Choapa</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Fraunces (display serif) + Source Sans 3 (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,600&family=Source+Sans+3:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- global.css importado en frontmatter para que Astro lo procese correctamente -->

    <!-- Netlify Identity Widget ─────────────────────────────────────────
         Permite que el botón "Log in" de cualquier página del sitio abra
         el flujo de autenticación y redirija a /admin/ tras hacer login.
         Solo añade peso cuando el usuario abre el modal; el script es lazy. -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>

  <body>
    <Nav currentPath={currentPath} />

    <main>
      <slot />
    </main>

    <Footer />

    <!-- Netlify Identity: manejo de tokens y redirección ───────────────
         Cubre tres casos:
         1. invite_token en la URL  → abre el widget para crear contraseña
         2. recovery_token en la URL → abre el widget para resetear contraseña
         3. login completado        → redirige a /admin/
    -->
    <script>
      (function () {
        // El widget puede no estar listo de forma síncrona; esperamos al evento
        // nativo que dispara netlify-identity-widget cuando termina de cargar.
        function initIdentity() {
          var ni = window.netlifyIdentity;
          if (!ni) return;

          ni.on('init', function (user) {
            // Detectar tokens de invitación o recuperación en el hash
            var hash = window.location.hash;
            if (
              hash.indexOf('invite_token=') !== -1 ||
              hash.indexOf('recovery_token=') !== -1
            ) {
              // El widget lee el hash por sí solo; solo necesita que lo abramos
              ni.open();
              return;
            }

            // Sin token: registrar redirección post-login
            if (!user) {
              ni.on('login', function () {
                document.location.href = '/admin/';
              });
            }
          });

          // Por si el evento 'init' ya se disparó antes de que este script
          // se ejecutara (race condition en páginas rápidas)
          if (ni.currentUser && ni.currentUser()) return;
        }

        // Ejecutar ahora si el widget ya está disponible; si no, esperar DOMContentLoaded
        if (window.netlifyIdentity) {
          initIdentity();
        } else {
          document.addEventListener('DOMContentLoaded', initIdentity);
        }
      })();
    </script>
  </body>
</html>
